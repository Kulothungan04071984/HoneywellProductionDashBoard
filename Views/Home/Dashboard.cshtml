@model ProductionDashboard.Models.DashboardViewModel

@{
    ViewData["Title"] = "Syrma SGS HoneyWell DashBaord";

    var shiftIcons = new Dictionary<string, string>
    {
        ["Night"] = "fa-moon",
        ["Morning"] = "fa-sun",
        ["Afternoon"] = "fa-cloud-sun"
    };

    var currentShift = Model.SelectedShift;

    var shiftLabel =
        currentShift == "Night" ? "Night Shift" :
        currentShift == "Morning" ? "Morning Shift" :
        "Afternoon Shift";

    var shiftTime =
        currentShift == "Night" ? "12:00 AM - 8:00 AM" :
        currentShift == "Morning" ? "8:00 AM - 4:00 PM" :
        "4:00 PM - 12:00 AM";

    var shiftClass =
        currentShift == "Night" ? "shift-night" :
        currentShift == "Morning" ? "shift-morning" :
        "shift-afternoon";

    var metrics = Model.ShiftMetrics;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HoneyWell DashBaord</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <style>
        :root {
            --bg-base: #0d1b2a;
            --bg-panel: #112233;
            --bg-card: #162840;
            --bg-header: #0a1520;
            --accent-blue: #29d4ff;
            --accent-green: #00ffb0;
            --accent-amber: #ffc53d;
            --accent-red: #ff4f7b;
            --accent-purple: #c47aff;
            --text-primary: #eef4ff;
            --text-muted: #7e9bbf;
            --border-glow: rgba(41,212,255,0.22);
            --shift-night: #c47aff;
            --shift-morning: #29d4ff;
            --shift-afternoon: #00ffb0;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
        }

        body {
            background: var(--bg-base);
            color: var(--text-primary);
            font-family: 'Exo 2', sans-serif;
            min-height: 100vh;
            background-image: radial-gradient(ellipse 80% 40% at 50% 0%, rgba(0,200,255,0.06) 0%, transparent 70%), repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(0,200,255,0.03) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,200,255,0.03) 40px);
        }

        /* ── Header ─────────────────────────────────────── */
        .app-header {
            background: linear-gradient(135deg, #060b18 0%, #0d1830 100%);
            border-bottom: 1px solid var(--border-glow);
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 4px 30px rgba(0,200,255,0.08);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .brand-icon {
            width: 42px;
            height: 42px;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            box-shadow: 0 0 20px rgba(0,200,255,0.4);
            animation: pulse-glow 3s ease-in-out infinite;
        }

        @@keyframes pulse-glow {
            0%, 100% {
                box-shadow: 0 0 20px rgba(0,200,255,0.4);
            }

            50% {
                box-shadow: 0 0 35px rgba(0,200,255,0.7);
            }
        }

        .brand-title {
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: 2px;
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-green));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .brand-sub {
            font-size: 0.85rem;
            color: var(--text-muted);
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        .header-meta {
            display: flex;
            align-items: center;
            gap: 2rem;
        }

        .live-badge {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(0,255,157,0.1);
            border: 1px solid rgba(0,255,157,0.3);
            border-radius: 20px;
            padding: 0.3rem 0.8rem;
            font-size: 0.75rem;
            color: var(--accent-green);
            font-weight: 600;
            letter-spacing: 1px;
        }

        .live-dot {
            width: 8px;
            height: 8px;
            background: var(--accent-green);
            border-radius: 50%;
            animation: blink 1.2s ease-in-out infinite;
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.2;
            }
        }

        .clock {
            font-family: 'Share Tech Mono', monospace;
            font-size: 1.3rem;
            color: var(--accent-blue);
            letter-spacing: 2px;
        }

        .refresh-badge {
            font-size: 0.7rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        /* ── Product Selector ─────────────────────────────── */
        .product-bar {
            padding: 1.2rem 2rem;
            background: var(--bg-panel);
            border-bottom: 1px solid var(--border-glow);
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .product-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
        }

        .product-select-wrapper {
            position: relative;
        }

        .product-select {
            background: var(--bg-card);
            color: var(--accent-blue);
            border: 1px solid var(--border-glow);
            border-radius: 8px;
            padding: 0.5rem 2.5rem 0.5rem 1rem;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: 2px;
            cursor: pointer;
            outline: none;
            appearance: none;
            transition: border-color 0.3s, box-shadow 0.3s;
            min-width: 140px;
        }

            .product-select:hover, .product-select:focus {
                border-color: var(--accent-blue);
                box-shadow: 0 0 15px rgba(0,200,255,0.2);
            }

        .product-select-icon {
            position: absolute;
            right: 0.8rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent-blue);
            pointer-events: none;
            font-size: 0.75rem;
        }

        .refresh-btn {
            background: linear-gradient(135deg, rgba(0,200,255,0.1), rgba(168,85,247,0.1));
            border: 1px solid var(--border-glow);
            color: var(--accent-blue);
            border-radius: 8px;
            padding: 0.5rem 1.2rem;
            font-family: 'Exo 2', sans-serif;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .refresh-btn:hover {
                background: linear-gradient(135deg, rgba(0,200,255,0.2), rgba(168,85,247,0.2));
                box-shadow: 0 0 20px rgba(0,200,255,0.3);
                transform: translateY(-1px);
            }

            .refresh-btn.spinning i {
                animation: spin 1s linear infinite;
            }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* ── Main Content ─────────────────────────────────── */
        .main-content {
            padding: 1.5rem 2rem;
        }

        /* ── Shift Panel ──────────────────────────────────── */
        .shift-panel {
            margin-bottom: 2rem;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.07);
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            animation: slideUp 0.5s ease both;
        }

            .shift-panel:nth-child(2) {
                animation-delay: 0.1s;
            }

            .shift-panel:nth-child(3) {
                animation-delay: 0.2s;
            }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .shift-header {
            padding: 0.9rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

            .shift-header::before {
                content: '';
                position: absolute;
                inset: 0;
                opacity: 0.08;
            }

        .shift-night .shift-header {
            background: linear-gradient(135deg, rgba(168,85,247,0.2), rgba(168,85,247,0.05));
            border-bottom: 2px solid rgba(168,85,247,0.4);
        }

        .shift-morning .shift-header {
            background: linear-gradient(135deg, rgba(0,200,255,0.2), rgba(0,200,255,0.05));
            border-bottom: 2px solid rgba(0,200,255,0.4);
        }

        .shift-afternoon .shift-header {
            background: linear-gradient(135deg, rgba(0,255,157,0.15), rgba(0,255,157,0.04));
            border-bottom: 2px solid rgba(0,255,157,0.4);
        }

        .shift-title-group {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .shift-icon {
            font-size: 1.3rem;
        }

        .shift-night .shift-icon {
            color: var(--shift-night);
        }

        .shift-morning .shift-icon {
            color: var(--shift-morning);
        }

        .shift-afternoon .shift-icon {
            color: var(--shift-afternoon);
        }

        .shift-name {
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.3rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .shift-night .shift-name {
            color: var(--shift-night);
        }

        .shift-morning .shift-name {
            color: var(--shift-morning);
        }

        .shift-afternoon .shift-name {
            color: var(--shift-afternoon);
        }

        .shift-time {
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.9rem;
            color: var(--text-muted);
            letter-spacing: 1px;
        }

        .shift-stats {
            display: flex;
            gap: 1.5rem;
            font-size: 0.7rem;
            color: var(--text-muted);
        }

        .stat-item {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .stat-val {
            font-family: 'Share Tech Mono', monospace;
            font-size: 1.1rem;
        }

        .stat-lbl {
            opacity: 0.6;
            letter-spacing: 1px;
        }

        /* ── Table ────────────────────────────────────────── */
        .table-wrap {
            overflow-x: auto;
            background: var(--bg-panel);
        }

        table.prod-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 1rem;
            min-width: 900px;
        }

        .prod-table th, .prod-table td {
            border: 1px solid rgba(255,255,255,0.05);
            text-align: center;
            padding: 0;
        }
        /* Top header row */
        .th-hour {
            background: var(--bg-header);
            color: var(--text-muted);
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.9rem;
        }

        .th-metric {
            background: var(--bg-header);
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: 2px;
            padding: 0.6rem 0.5rem;
            color: var(--accent-blue);
        }

        .th-sub {
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            padding: 0.4rem 0.5rem;
            text-transform: uppercase;
        }

            .th-sub.sub-target {
                background: rgba(0,200,255,0.06);
                color: var(--accent-blue);
            }

            .th-sub.sub-actual {
                background: rgba(0,255,157,0.06);
                color: var(--accent-green);
            }

        .th-hour-label {
            background: var(--bg-header);
            color: var(--text-muted);
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.65rem;
            letter-spacing: 1px;
            padding: 0.3rem;
        }

        /* Data cells */
        .td-hour {
            background: var(--bg-card);
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.9rem;
            color: var(--text-muted);
            padding: 0.65rem 0.7rem;
            white-space: nowrap;
            position: sticky;
            left: 0;
            z-index: 1;
            border-right: 1px solid rgba(255,255,255,0.1) !important;
        }

        .td-val {
            padding: 0.6rem 0.5rem;
            font-family: 'Share Tech Mono', monospace;
            font-size: 1rem;
            transition: background 0.3s;
        }

            .td-val.target {
                color: rgba(0,200,255,0.7);
                background: rgba(0,200,255,0.03);
            }

            .td-val.actual-ok {
                color: var(--accent-green);
                background: rgba(0,255,157,0.05);
            }

            .td-val.actual-warn {
                color: var(--accent-amber);
                background: rgba(255,179,0,0.05);
            }

            .td-val.actual-bad {
                color: var(--accent-red);
                background: rgba(255,61,107,0.05);
            }

        /* Cumulative row */
        .cum-section {
            background: var(--bg-panel);
        }

        .cum-header-row th {
            background: rgba(168,85,247,0.08);
            border-top: 2px solid rgba(168,85,247,0.3) !important;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1.05rem;
            color: var(--accent-purple);
            font-weight: 700;
            letter-spacing: 2px;
            padding: 0.6rem;
        }

        .cum-data-row {
            animation: fadeIn 0.4s ease both;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .td-cumval {
            padding: 0.55rem 0.5rem;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.95rem;
            background: rgba(168,85,247,0.04);
            color: var(--accent-purple);
            transition: all 0.5s ease;
        }

            .td-cumval.cum-target {
                color: rgba(0,200,255,0.6);
                background: rgba(0,200,255,0.04);
            }

            .td-cumval.updated {
                animation: flash 0.6s ease;
            }

        @@keyframes flash {
            0% {
                background: rgba(168,85,247,0.3);
            }

            100% {
                background: rgba(168,85,247,0.04);
            }
        }

        .cum-label-cell {
            background: rgba(168,85,247,0.08);
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--accent-purple);
            letter-spacing: 1px;
            padding: 0.4rem 0.5rem;
            position: sticky;
            left: 0;
            z-index: 1;
            white-space: nowrap;
        }

        .cum-hour-lbl {
            font-size: 0.6rem;
            display: block;
            color: var(--text-muted);
            margin-top: 1px;
        }

        /* ── Scrollbar ────────────────────────────────────── */
        ::-webkit-scrollbar {
            height: 5px;
            width: 5px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-base);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(0,200,255,0.3);
            border-radius: 3px;
        }

        /* ── Progress bar in shift-stats ─────────────────── */
        .mini-progress {
            width: 80px;
            height: 4px;
            background: rgba(255,255,255,0.1);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 3px;
        }

        .mini-progress-fill {
            height: 100%;
            border-radius: 2px;
            transition: width 1s ease;
        }

        .ok .mini-progress-fill {
            background: var(--accent-green);
        }

        .warn .mini-progress-fill {
            background: var(--accent-amber);
        }

        .bad .mini-progress-fill {
            background: var(--accent-red);
        }

        /* ── Footer ──────────────────────────────────────── */
        .app-footer {
            padding: 1rem 2rem;
            border-top: 1px solid var(--border-glow);
            background: var(--bg-panel);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.7rem;
            color: var(--text-muted);
            letter-spacing: 1px;
        }

        .countdown-bar {
            width: 120px;
            height: 3px;
            background: rgba(255,255,255,0.1);
            border-radius: 2px;
            overflow: hidden;
        }

        .countdown-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple));
            border-radius: 2px;
            transition: width 1s linear;
        }
    </style>
    <style>
        .prod-table {
            width: 100%;
            border-collapse: collapse;
            background: #071426;
            color: #00e5ff;
            font-family: 'Segoe UI';
            text-align: center;
            overflow: hidden;
            border-radius: 12px;
        }

            .prod-table th,
            .prod-table td {
                border: 1px solid rgba(0,255,255,0.08);
                padding: 10px;
            }

        .group-head {
            background: #081b33;
            color: #00e5ff;
            font-size: 22px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .sub-head {
            background: #0c2947;
            color: #00ffc8;
            font-size: 16px;
        }

        .hour-col {
            background: #14243b;
            color: #8fb7ff;
            width: 120px;
            font-size: 18px;
        }

        .hour-cell {
            background: #182b47;
            color: #9cc7ff;
            font-weight: bold;
            font-size: 16px;
        }

        .target-cell {
            background: rgba(0,180,255,0.08);
            color: #00cfff;
            font-weight: 600;
        }

        .actual-ok {
            background: rgba(0,255,170,0.08);
            color: #00ffbf;
            font-weight: bold;
            font-size: 18px;
        }

        .actual-warn {
            background: rgba(255,193,7,0.08);
            color: #ffd54f;
            font-weight: bold;
            font-size: 18px;
        }

        .actual-bad {
            background: rgba(255,0,85,0.08);
            color: #ff4f7b;
            font-weight: bold;
            font-size: 18px;
        }

        .prod-table tbody tr:hover {
            background: rgba(0,255,255,0.03);
            transition: 0.3s;
        }

        .header-logo {
            height: 38px; /* fixed height, fits the header bar */
            width: auto; /* preserves aspect ratio */
            object-fit: contain;
            opacity: 0.92;
            filter: brightness(1.1); /* slight boost on dark background */
        }
    </style>
</head>
<body>
    <header class="app-header">
        <div class="brand">
            <div class="brand-icon"><i class="fas fa-industry"></i></div>
            <div>
                <div class="brand-title">HONEYWELL PRODUCTION MONITOR</div>
                <div class="brand-sub">Real-time shift dashboard</div>
            </div>
        </div>
        <div class="header-meta">
            <div>
                <img src="@Url.Content("~/Images/syrma-logo.png")" class="header-logo" alt="Logo" />
            </div>
            <div class="live-badge">
                <div class="live-dot"></div>
                LIVE
            </div>
            <div class="clock" id="clock">--:--:--</div>
            <div class="refresh-badge">
                <i class="fas fa-sync-alt"></i>
                Auto-refresh: <span id="countdown-text">60s</span>
            </div>

        </div>
    </header>
    <div class="product-bar">
        <span class="product-label"><i class="fas fa-box me-1"></i> Product</span>
        <div class="product-select-wrapper">
            <select class="product-select" id="productSelect" onchange="changeProduct(this.value)">
                @foreach (var p in Model.Products)
                {
                    <option value="@p" @(p == Model.SelectedProduct ? "selected" : "")>@p</option>
                }
            </select>
            <i class="fas fa-chevron-down product-select-icon"></i>
        </div>
        <button class="refresh-btn" id="refreshBtn" onclick="manualRefresh()">
            <i class="fas fa-sync-alt" id="refreshIcon"></i> REFRESH
        </button>

        <div class="col-lg-2" style="margin-top:-1%;">
            <label class="form-label mb-1 text-muted small fw-semibold">From Date</label>
            <input type="date" id="fromDate" class="form-control" />
        </div>
        <div class="col-lg-2" style="margin-top:-1%;">
            <label class="form-label mb-1 text-muted small fw-semibold">To Date</label>
            <input type="date" id="toDate" class="form-control" />
        </div>
        <button class="btn btn-primary" id="btnShow">
            <i class="bi bi-search"></i> Show
        </button>

        <div class="ms-auto" style="font-size:0.75rem; color:var(--text-muted);">
            <i class="fas fa-calendar-day me-1"></i>
            <span id="dateLabel"></span>
        </div>
    </div>
    <main class="main-content" id="dashboardMain">
        @* @{
            var shiftIcons = new Dictionary<string, string>
            {
                ["Night"] = "fa-moon",
                ["Morning"] = "fa-sun",
                ["Afternoon"] = "fa-cloud-sun"
            };
        } *@
        @*  @foreach (var (shiftKey, shiftLabel, shiftTime, shiftClass, metrics) in shifts) *@

        <div class="shift-panel @shiftClass" id="panel-@currentShift">

            <div class="shift-header">
                <div class="shift-title-group">
                    <i class="fas @shiftIcons[currentShift] shift-icon"></i>
                    <div>
                        <div class="shift-name">@shiftLabel</div>
                        <div class="shift-time">@shiftTime</div>
                    </div>
                </div>
                <div class="shift-stats" id="stats-@currentShift">
                    @* Filled by JS *@
                </div>
            </div>

            <div class="table-wrap">
                <table class="prod-table" id="table-@currentShift">

                    @{
                        var testerGroups = metrics
                        .Select(x => x.TesterGroup)
                        .Distinct()
                        .OrderBy(x => x)
                        .ToList();

                        // var hourSlots = metrics
                        // .Select(x => x.HourSlot)
                        // .Distinct()
                        // .OrderBy(x => x)
                        // .ToList();
                        var hourSlots = metrics
                        .GroupBy(x => x.HourSlot)
                        .Select(g => new
                        {
                            HourSlot = g.Key,
                            HourRange = g.First().HourRange
                        })
                        .OrderBy(x => x.HourSlot)
                        .ToList();
                    }

                    <thead>

                        <tr>
                            <th rowspan="2" class="hour-col">
                                HOUR
                            </th>

                            @foreach (var tg in testerGroups)
                            {
                                <th colspan="2" class="group-head">
                                    @tg
                                </th>
                            }
                        </tr>

                        <tr>
                            @foreach (var tg in testerGroups)
                            {
                                <th class="sub-head">
                                    TARGET
                                </th>

                                <th class="sub-head">
                                    ACTUAL
                                </th>
                              @*   <th class="sub-head">
                                    GAP
                                </th>
                                <th class="sub-head">
                                    LOSS%
                                </th> *@
                            }

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var hour in hourSlots)
                        {
                            <tr class="data-row" data-hour="@hour">

                                <td class="hour-cell">
                                    @hour.HourRange
                                </td>

                                @foreach (var tg in testerGroups)
                                {
                                    var row = metrics.FirstOrDefault(x =>
                                    x.HourSlot == hour.HourSlot &&
                                    x.TesterGroup == tg);

                                    decimal tgt = row?.Target ?? 0;
                                    decimal act = row?.Actual ?? 0;
                                    decimal gap = tgt - act;
                                    decimal lossPct = tgt > 0 ? (gap / tgt) * 100 : 0;

                                    var pct = tgt > 0
                                    ? (double)act / (double)tgt * 100
                                    : 0;

                                    var cls = pct >= 95
                                    ? "actual-ok"
                                    : pct >= 80
                                    ? "actual-warn"
                                    : "actual-bad";

                                    <td class="target-cell">
                                        @(row == null ? "-" : tgt.ToString("0"))
                                    </td>

                                    <td class="td-val @cls"
                                        data-tgt="@tgt"
                                        data-act="@act">

                                        @(row == null ? "-" : act.ToString("0"))

                                    </td>
                                   @*  <td class="td-val">
                                        @(row == null ? "-" : gap.ToString("0"))
                                    </td>
                                    <td class="td-val">
                                        @(row == null ? "-" : lossPct.ToString("0.##") + "%")
                                    </td> *@
                                }

                            </tr>
                        }

                    </tbody>

                    <!-- CUMULATIVE -->

                    <tbody class="cum-section">

                        <tr class="cum-header-row">

                            <th>
                                CUMULATIVE
                            </th>

                            @foreach (var tg in testerGroups)
                            {
                                <th colspan="2" style="text-align:left;">
                                    @tg
                                </th>
                            }

                        </tr>

                        @foreach (var hour in hourSlots)
                        {
                            <tr class="cum-data-row"
                                data-cum-hour="@hour">

                                <td class="cum-label-cell">

                                    @hour.HourRange

                                   @*  <span class="cum-hour-lbl">
                                        @hour.HourRange hr cumulative
                                    </span> *@

                                </td>

                                @foreach (var tg in testerGroups)
                                {
                                    var cumRows = metrics
                                    .Where(x =>
                                    x.HourSlot <= hour.HourSlot &&
                                    x.TesterGroup == tg)
                                    .ToList();

                                    decimal cumTgt = cumRows.Sum(x => x.Target);
                                    decimal cumAct = cumRows.Sum(x => x.Actual);

                                    var cumPct = cumTgt > 0
                                    ? (double)cumAct / (double)cumTgt * 100
                                    : 0;

                                    var cumCls = cumPct >= 95
                                    ? "actual-ok"
                                    : cumPct >= 80
                                    ? "actual-warn"
                                    : "actual-bad";

                                    <td class="td-cumval cum-target">
                                        @(cumRows.Any() ? cumTgt.ToString("0") : "-")
                                    </td>

                                    <td class="td-cumval @cumCls">
                                        @(cumRows.Any() ? cumAct.ToString("0") : "-")
                                    </td>
                                  
                                }

                            </tr>
                        }

                    </tbody>

                </table>
            </div>
        </div>
        </div>


    </main>
    <footer class="app-footer">
        <span>SyrmaSGS HoneyWell DashBaord</span>
        <div style="display:flex; align-items:center; gap:0.8rem;">
            <span>Next refresh in <span id="footerCount">60</span>s</span>
            <div class="countdown-bar">
                <div class="countdown-fill" id="countdownFill" style="width:100%"></div>
            </div>
        </div>
    </footer>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script>
               const REFRESH_INTERVAL = 60;   // seconds
               const COLS = ['FCT1','FCT2'];
               const SHIFTS = ['Night','Morning','Afternoon'];
               const CURRENT_SHIFT = '@Model.SelectedShift';
               let currentProduct = '@Model.SelectedProduct';
               let countdown = REFRESH_INTERVAL;
               let refreshTimer;

               /* ── Show Button: Validate + Fetch History ─────────────────────────── */
        $('#btnShow').on('click', function () {
            debugger;
            // 1. Clear previous errors
            $('#fromDate, #toDate').css('border-color', '');
            $('#fromDateError, #toDateError').text('');

            var from    = $('#fromDate').val();   // e.g. "2026-06-15"  (yyyy-MM-dd from input[type=date])
            var to      = $('#toDate').val();
            var product = $('#productSelect').val();
            var isValid = true;

            // 2. Validation
            if (!from) {
                $('#fromDate').css('border-color', 'var(--accent-red)');
                $('#fromDateError').text('From Date is required.');
                isValid = false;
            }

            if (!to) {
                $('#toDate').css('border-color', 'var(--accent-red)');
                $('#toDateError').text('To Date is required.');
                isValid = false;
            }

            if (from && to && new Date(from) > new Date(to)) {
                $('#fromDate').css('border-color', 'var(--accent-red)');
                $('#fromDateError').text('From Date must be less than or equal to To Date.');
                isValid = false;
            }

            if (!isValid) return;

            // 3. Show loading state on all shift panels
            SHIFTS.forEach(function (s) {
                $('#loading-' + s).show();
                $('#tablewrap-' + s).hide();
                $('#stats-' + s).html('');
                $('#badge-' + s).text('...');
            });

            // 4. Convert yyyy-MM-dd → dd-MM-yyyy  (format your SP expects: 105)
            function toDisplayFormat(isoDate) {
                var parts = isoDate.split('-');           // ["2026","06","15"]
                return parts[2] + '-' + parts[1] + '-' + parts[0];  // "15-06-2026"
            }

            var fromFmt = toDisplayFormat(from);
            var toFmt   = toDisplayFormat(to);

            // 5. AJAX call
        //     $.ajax({
        //     url:  '/Home/DashBoardHistory',
        //     type: 'GET',
        //     data: {
        //         product:  product,
        //         fromdate: fromFmt,
        //         todate:   toFmt
        //     },
        //     success: function (response) {
        //       debugger;
        //         window.location.href = '/Home/DashBoardHistoryView?product='
        //             + encodeURIComponent(product)
        //             + '&fromdate=' + encodeURIComponent(fromFmt)
        //             + '&todate='   + encodeURIComponent(toFmt);
        //     },
        //     error: function (xhr, status, err) {
        //         console.error('DashBoardHistory error:', err);
        //         SHIFTS.forEach(function (s) {
        //             $('#loading-' + s).hide();
        //             $('#tablewrap-' + s).show();
        //             $('#table-' + s).html(
        //                 '<tbody><tr><td colspan="20" style="padding:2rem;color:var(--accent-red);' +
        //                 'font-family:\'Share Tech Mono\',monospace;letter-spacing:2px;">' +
        //                 'ERROR LOADING DATA. PLEASE TRY AGAIN.</td></tr></tbody>'
        //             );
        //         });
        //     },
        //     complete: function () {
        //         SHIFTS.forEach(function (s) {
        //             $('#loading-' + s).hide();
        //             $('#tablewrap-' + s).show();
        //         });
        //     }
        // });
            window.location.href = '/Home/DashBoardHistoryView?product='
        + encodeURIComponent(product)
        + '&fromdate=' + encodeURIComponent(fromFmt)
        + '&todate='   + encodeURIComponent(toFmt);
        });

        // Clear validation highlight when user changes date inputs
        $('#fromDate, #toDate').on('change', function () {
            $(this).css('border-color', '');
            $('#' + $(this).attr('id') + 'Error').text('');
        });
                    /* ── Clock ──────────────────────────────────────── */
               function updateClock() {
                   const now = new Date();
                   document.getElementById('clock').textContent =
                       now.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
                   document.getElementById('dateLabel').textContent =
                       now.toLocaleDateString('en-GB', {weekday:'short',day:'2-digit',month:'short',year:'numeric'});
               }
               setInterval(updateClock, 1000);
               updateClock();
                    /* ── Countdown ──────────────────────────────────── */
               function startCountdown() {
                   clearInterval(refreshTimer);
                   countdown = REFRESH_INTERVAL;
                   refreshTimer = setInterval(() => {
                       countdown--;
                       const pct = (countdown / REFRESH_INTERVAL) * 100;
                       document.getElementById('footerCount').textContent = countdown;
                       document.getElementById('countdown-text').textContent = countdown + 's';
                       document.getElementById('countdownFill').style.width = pct + '%';
                       if (countdown <= 0) { autoRefresh(); }
                   }, 1000);
               }

                    /* ── Refresh ─────────────────────────────────────── */
               async function autoRefresh() {
                   @* await loadAllShifts(currentProduct); *@
                                  await loadShift(currentProduct, CURRENT_SHIFT);
                   startCountdown();
               }
                    function manualRefresh() {
                   const btn = document.getElementById('refreshBtn');
                   btn.classList.add('spinning');
                   setTimeout(() => btn.classList.remove('spinning'), 800);
                   autoRefresh();
               }

                    function changeProduct(val) {
                   currentProduct = val;
                   history.replaceState(null, '', '?product=' + encodeURIComponent(val));
                   autoRefresh();
                    }

                        async function loadAllShifts(product) {
                   await Promise.all(SHIFTS.map(s => loadShift(product, s)));
               }

               async function loadShift(product, shift) {
                   try {
                       const res  = await fetch(`/api/metrics?product=${encodeURIComponent(product)}&shift=${encodeURIComponent(shift)}`);
                       const data = await res.json();
                       renderShift(shift, data);
                   } catch(e) {
                            console.error(e);
                   }
               }

             @*   function renderShift(shift, metrics) {
            renderDataRows(shift, metrics);
            renderCumRows(shift, metrics);
            renderShiftStats(shift, metrics);
        } *@
                       function renderShift(shift, metrics) {

                   const table = document.getElementById('table-' + shift);

                   if (!metrics.length) return;

                   const testerGroups =
                       [...new Set(metrics.map(x => x.testerGroup))];

                    const hourSlots =
                        [...new Map(
                            metrics.map(x => [x.hourSlot, x.hourRange])
                        ).entries()];

                

                   let html = `

                       <thead>

                           <tr>
                               <th rowspan="2" class="hour-col">
                                   HOUR
                               </th>

                               ${testerGroups.map(tg =>
                                   `<th colspan="2" class="group-head">${tg}</th>`
                               ).join('')}

                           </tr>

                           <tr>

                               ${testerGroups.map(tg => `
                                   <th class="sub-head">TARGET</th>
                                   <th class="sub-head">ACTUAL</th>
                                   
                               `).join('')}

                           </tr>

                       </thead>

                       <tbody>
                   `;

                       hourSlots.forEach(([hourSlot, hourRange]) => {
                     debugger;
                       html += `<tr class="data-row">`;

                       html += `
                           <td class="hour-cell">
                              ${hourRange}
                           </td>
                       `;

                       testerGroups.forEach(tg => {

                           const row = metrics.find(x =>
                                   x.hourSlot === hourSlot &&
                               x.testerGroup === tg);

                           const tgt = row ? row.target : 0;
                           const act = row ? row.actual : 0;
                           const gap = tgt - act;
                           const lossPct = tgt > 0 ? (gap / tgt) * 100 : 0;

                           const pct = tgt > 0
                               ? (act / tgt) * 100
                               : 0;

                           const cls =
                               pct >= 95
                               ? 'actual-ok'
                               : pct >= 80
                               ? 'actual-warn'
                               : 'actual-bad';

                           html += `
                               <td class="target-cell">
                                   ${row ? tgt.toFixed(0) : '-'}
                               </td>

                               <td class="td-val ${cls}">
                                   ${row ? act.toFixed(0) : '-'}
                               </td>
                              
                           `;
                       });

                       html += `</tr>`;
                   });

                   html += `</tbody>`;

                       /* CUMULATIVE  <td class="td-val">
                                       ${row ? gap.toFixed(0) : '-'}
                                   </td>
                                   <td class="td-val">
                                       ${row ? lossPct.toFixed(2) + '%' : '-'}
                                       </td>  <span class="cum-hour-lbl">
                                                             Cumulative up to ${hourRange}
                                       </span>*/

                   html += `
                       <tbody class="cum-section">

                           <tr class="cum-header-row">

                               <th>CUMULATIVE</th>

                               ${testerGroups.map(tg =>
                                   `<th colspan="2">${tg}</th>`
                               ).join('')}

                           </tr>
                   `;

                       hourSlots.forEach(([hourSlot, hourRange]) => {

                       html += `
                           <tr class="cum-data-row">

                               <td class="cum-label-cell">

                                                     ${hourRange}

                                  

                               </td>
                       `;

                       testerGroups.forEach(tg => {

                           const rows = metrics.filter(x =>
                                   x.hourSlot <= hourSlot &&
                               x.testerGroup === tg);

                           const cumTgt =
                               rows.reduce((s,x) => s + x.target, 0);

                           const cumAct =
                               rows.reduce((s,x) => s + x.actual, 0);

                           const pct =
                               cumTgt > 0
                               ? (cumAct / cumTgt) * 100
                               : 0;

                           const cls =
                               pct >= 95
                               ? 'actual-ok'
                               : pct >= 80
                               ? 'actual-warn'
                               : 'actual-bad';

                           html += `
                               <td class="td-cumval cum-target">
                                   ${cumTgt.toFixed(0)}
                               </td>

                               <td class="td-cumval ${cls}">
                                   ${cumAct.toFixed(0)}
                               </td>
                              
                           `;
                       });

                       html += `</tr>`;
                   });

                   html += `</tbody>`;

                   table.innerHTML = html;

                   renderShiftStats(shift, metrics);
               }
                       function renderShiftStats(shift, metrics) {

                   if (!metrics.length) return;

                   const statsEl =
                       document.getElementById('stats-' + shift);

                   const totTgt =
                       metrics.reduce((s,m) => s + m.target, 0);

                   const totAct =
                       metrics.reduce((s,m) => s + m.actual, 0);

                   const pct =
                       totTgt > 0
                       ? Math.round((totAct / totTgt) * 100)
                       : 0;

                   const cls =
                       pct >= 95
                       ? 'ok'
                       : pct >= 80
                       ? 'warn'
                       : 'bad';

                   const clr =
                       pct >= 95
                       ? 'var(--accent-green)'
                       : pct >= 80
                       ? 'var(--accent-amber)'
                       : 'var(--accent-red)';

                   const hours =
                       [...new Set(metrics.map(x => x.hourSlot))];

                   statsEl.innerHTML = `
                       <div class="stat-item ${cls}">
                           <span class="stat-val"
                                 style="color:${clr}">
                                 ${pct}%
                           </span>

                           <span class="stat-lbl">
                               Overall
                           </span>

                           <div class="mini-progress">
                               <div class="mini-progress-fill"
                                    style="width:${Math.min(pct,100)}%">
                               </div>
                           </div>
                       </div>

                       <div class="stat-item">
                           <span class="stat-val">
                               ${hours.length}/8
                           </span>

                           <span class="stat-lbl">
                               Hours
                           </span>
                       </div>
                   `;
               }
                  @*  function renderDataRows(shift, metrics) {
            const tbl  = document.getElementById('table-' + shift);
            const rows = tbl.querySelectorAll('tbody:first-of-type .data-row');
            rows.forEach(row => {
